# Gemini API access (AI Studio key)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Arize Phoenix Cloud (tracing + online self-evaluation)
PHOENIX_API_KEY=
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com
PHOENIX_PROJECT=pacl-dev

# Coordination mode: "scaffolded" (Python pre-detects overlap) or "agnostic" (the model decides)
PACL_MODE=scaffolded
# Seconds before a stale intent ages out of overlap detection
PACL_INTENT_TTL=3600

# Substrate (local-disk markdown)
SUBSTRATE_LOCAL_ROOT=./substrate

# Server
PORT=8080
LOG_LEVEL=INFO
